# --- DATABASE ---
# URL de conexión a la base de datos PostgreSQL
# Ejemplo: postgresql://USER:PASSWORD@db:5432/turnos_db?schema=public
DATABASE_URL=postgresql://auteide:auteide_pass@db:5432/turnos_db?schema=public

# --- SECURITY ---
# Secreto para firmar los tokens JWT. 
# ¡IMPORTANTE!: En producción DEBE ser una cadena larga, aleatoria y segura.
JWT_SECRET=cambiar_por_algo_muy_seguro_en_produccion

# --- ENVIRONMENT ---
NODE_ENV=production
PORT=3000

# --- CORS & FRONTEND ---
# URL del frontend para permitir peticiones (CORS)
FRONTEND_URL=https://tu-dominio-produccion.com
